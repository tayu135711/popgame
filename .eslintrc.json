{
  "env": {
    "browser": true,
    "es2021": true
  },
  "rules": {
    "no-unused-vars": "warn",      // 使っていない変数があったら警告
    "no-undef": "warn",            // 未定義の変数を使ったら警告
    "no-console": "off",           // console.log はゲームでよく使うのでOK
    "semi": ["warn", "always"],    // セミコロン忘れを警告
    "no-duplicate-case": "error"   // switch文の重複caseはエラー
  }
}
